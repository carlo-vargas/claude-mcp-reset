{
  "mcpServers": {
    "remote-notion-wiki": {
      "type": "http",
      "url": "https://notion.com",
      "headers": {
        "Authorization": "Bearer ntn_your_secret_key_here",
        "X-Notion-Version": "2022-06-28"
      }
    },
    "internal-company-api": {
      "type": "streamable-http",
      "url": "https://company.com",
      "headers": {
        "X-API-Key": "${COMPANY_API_KEY}"
      }
    },
    "local-filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/username/Projects"
      ]
    }
  },
  "projects": {
    "PROJECT_PLACEHOLDER": {
      "mcpServers": {
        "internal-company-api": {
          "type": "sse",
          "url": "http://localhost:3000/events"
        },
        "fetch-ftp": {
          "command": "uvx",
          "args": ["mcp-server-ftp"]
        }
      }
    },
    "/other/project": {
      "mcpServers": {
        "fetch-webpage": {
          "command": "uvx",
          "args": ["mcp-server-fetch"]
        }
      }
    }
  }
}
